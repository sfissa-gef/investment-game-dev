# investment-game — env template
#
# Copy to .env.local (gitignored) and fill in real values:
#   cp .env.example .env.local
#
# .env.local is loaded automatically by scripts/generate-narration.sh.
# NEVER commit .env.local or any file with a real API key.

# ─────────────────────────────────────────────────────────────
# ElevenLabs — neural TTS for narration audio
# ─────────────────────────────────────────────────────────────

# API key from https://elevenlabs.io → Profile → API Keys.
# Minimum permission: "Text to Speech".
ELEVENLABS_API_KEY=sk_your_key_here

# Default voice ID used when no per-language override is set.
# Current production voice: Mapendo (East African English/Luganda fit).
#   Voice ID: dOqxOZEisn8SiUH1dPCC
# Browse library voices at https://elevenlabs.io/voice-library
ELEVENLABS_VOICE_ID=dOqxOZEisn8SiUH1dPCC

# Model — keep eleven_multilingual_v2 so one voice ID can speak multiple languages.
ELEVENLABS_MODEL=eleven_multilingual_v2

# Voice tuning (0.0–1.0). Lower stability = more expressive but less consistent.
ELEVENLABS_STABILITY=0.55
ELEVENLABS_SIMILARITY=0.75

# ─────────────────────────────────────────────────────────────
# Per-language voice overrides (optional)
# ─────────────────────────────────────────────────────────────
#
# Uncomment and set to use a different voice for a specific language.
# The narration script checks ELEVENLABS_VOICE_ID_<LANG> first and falls
# back to ELEVENLABS_VOICE_ID if unset. Run the script with LANG_CODE=xx
# to target a language, e.g.:
#
#   LANG_CODE=lg BACKEND=elevenlabs ./scripts/generate-narration.sh
#
# Suggested vetting workflow before switching a language's production voice:
#   1. Preview 2–3 candidate voices on a short sample script
#   2. Native speaker confirms accent + pronunciation
#   3. Document choice in docs/voice-vetting/<lang>.md (create when needed)
#   4. Update the matching line below, re-run generate-narration.sh

# English (Uganda/Zambia rural):      Mapendo — current default
# ELEVENLABS_VOICE_ID_EN=dOqxOZEisn8SiUH1dPCC

# Luganda (Uganda):                   TBD — defaults to Mapendo for now
# ELEVENLABS_VOICE_ID_LG=

# Acholi (northern Uganda):           TBD
# ELEVENLABS_VOICE_ID_ACH=

# Swahili (East Africa regional):     TBD
# ELEVENLABS_VOICE_ID_SW=

# Bemba (Zambia):                     TBD — not in Waxal; needs commissioned audio
# ELEVENLABS_VOICE_ID_BEM=

# ─────────────────────────────────────────────────────────────
# Backend selection
# ─────────────────────────────────────────────────────────────

# 'elevenlabs' (production) or 'say' (macOS dev, robotic but free/offline).
BACKEND=elevenlabs
