{
  "name": "investment-game-server",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "description": "Cloudflare Worker + Neon Postgres sync backend for the Investment Game PWA",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "tail": "wrangler tail",
    "migrate": "dotenv -e .env -- node-pg-migrate up --migrations-dir migrations --database-url-var DATABASE_URL",
    "migrate:down": "dotenv -e .env -- node-pg-migrate down --migrations-dir migrations --database-url-var DATABASE_URL",
    "test": "node --test test/"
  },
  "dependencies": {
    "@neondatabase/serverless": "^0.10.4",
    "hono": "^4.6.14",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "dotenv-cli": "^7.4.4",
    "node-pg-migrate": "^7.9.1",
    "pg": "^8.13.1",
    "wrangler": "^3.100.0"
  }
}
